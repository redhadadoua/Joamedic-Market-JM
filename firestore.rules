rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'redhadadoua@gmail.com';
    }
    
    function isModerator() {
      return request.auth != null && exists(/databases/$(database)/documents/moderators/$(request.auth.token.email));
    }

    match /{document=**} {
      allow read, write: if false;
    }
    
    match /orders/{orderId} {
      allow create: if true;
      allow get: if true;
      allow list, update, delete: if isAdmin() || isModerator();
    }
    
    match /moderators/{email} {
      allow read: if isAdmin() || isModerator();
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
