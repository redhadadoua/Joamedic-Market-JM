rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email.lower() == 'redhadadoua@gmail.com';
    }
    
    function isModerator() {
      return request.auth != null && exists(/databases/$(database)/documents/moderators/$(request.auth.token.email.lower()));
    }

    match /{document=**} {
      allow read, write: if false;
    }
    
    match /orders/{orderId} {
      allow create: if 
        // Validate required fields
        request.resource.data.keys().hasAll(['customerName', 'phone', 'wilaya', 'baladiya', 'address', 'price', 'quantity', 'status']) &&
        // Validate data types
        request.resource.data.customerName is string &&
        request.resource.data.phone is string &&
        request.resource.data.price is number &&
        request.resource.data.quantity is number &&
        // Validate logic
        request.resource.data.status == 'pending' &&
        request.resource.data.quantity > 0 &&
        request.resource.data.price == (request.resource.data.quantity * 3700);
        
      allow get: if true;
      allow list, update, delete: if isAdmin() || isModerator();
    }
    
    match /moderators/{email} {
      allow read: if isAdmin() || isModerator();
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
